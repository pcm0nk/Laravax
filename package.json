{
  "name": "Laranux",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "dev": "nuxi dev",
    "build": "nuxi build",
    "start": "node .output/server/index.mjs",
    "lint": "yarn lint:js",
    "lint:js": "eslint --ext .ts,.js,.vue --ignore-path .gitignore .",
    "lint:action": "yarn lint:js -f @jamesacarr/github-actions",
    "style": "composer cs; yarn lint",
    "test": "jest --config tests/js/jest.config.js",
    "api": "./artisan serve",
    "seed": "./artisan migrate:fresh --seed",
    "caches": "./artisan config:cache; ./artisan route:cache; ./artisan cache:clear; ./artisan event:clear;",
    "stan": "composer stan"
  },
  "dependencies": {
    "@mdi/font": "^7.1.96",
    "@pinia/nuxt": "^0.4.7",
    "pinia": "^2.0.33",
    "pinia-plugin-persistedstate": "^3.1.0",
    "vite-plugin-vuetify": "^1.0.2",
    "vuetify": "^3.1.8"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.35.1",
    "@iconify/vue": "^4.0.0",
    "@jamesacarr/eslint-formatter-github-actions": "^0.1.0",
    "@tailvue/nuxt": "^0.1.62",
    "@types/js-cookie": "^3.0.3",
    "@typescript-eslint/eslint-plugin": "^5.38.1",
    "@vueuse/nuxt": "^9.1.0",
    "dayjs": "^1.10.7",
    "eslint": "^8.33.0",
    "husky": "^8.0.1",
    "laravel-echo": "^1.11.7",
    "lottie-web": "^5.8.1",
    "nuxt": "^3.0.0",
    "nuxt-windicss": "^2.5.5",
    "pusher-js": "^8.0.0",
    "sass": "^1.59.3",
    "typescript": "^4.8.4"
  }
}
